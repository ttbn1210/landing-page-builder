@page
@model DashboardModel
@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Dashboard";
}

@if (!User.Identity?.IsAuthenticated == true)
{
    <div class="alert alert-warning mt-4 mx-4">Please <a href="/Identity/Account/Login">login</a> to access your dashboard.</div>
}
else
{
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>My Landing Pages</h1>
            <a href="/Pages/Create" class="btn btn-primary">+ Create New Page</a>
        </div>

        @if (Model.LandingPages.Any())
        {
            <div class="row g-4">
                @foreach (var page in Model.LandingPages)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@page.Title</h5>
                                <p class="card-text text-muted">@page.Description</p>
                                <p class="small"><strong>Slug:</strong> @page.Slug</p>
                                <p class="small">
                                    <strong>Status:</strong>
                                    @if (page.IsPublished)
                                    {
                                        <span class="badge bg-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Draft</span>
                                    }
                                </p>
                            </div>
                            <div class="card-footer bg-light">
                                <a href="/Pages/Edit/@page.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a href="/Pages/View/@page.Slug" class="btn btn-sm btn-outline-primary" target="_blank">Preview</a>
                                <button type="submit" class="btn btn-sm btn-danger" onclick="deletePage(@page.Id)">Delete</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info text-center py-5">
                <p>You haven't created any landing pages yet.</p>
                <a href="/Pages/Create" class="btn btn-primary">Create Your First Page</a>
            </div>
        }
    </div>

    <script>
        function deletePage(pageId) {
            if (confirm('Are you sure you want to delete this page?')) {
                fetch(`/api/pages/${pageId}`, { method: 'DELETE' })
                    .then(response => {
                        if (response.ok) {
                            location.reload();
                        } else {
                            alert('Failed to delete page');
                        }
                    });
            }
        }
    </script>
}
