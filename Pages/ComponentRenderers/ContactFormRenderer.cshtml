@model PageComponent
@using System.Text.Json

@{
    var formData = JsonSerializer.Deserialize<JsonElement>(Model.Content);
    var title = formData.TryGetProperty("title", out var t) ? t.GetString() : "Contact Us";
    var description = formData.TryGetProperty("description", out var d) ? d.GetString() : "";
    var recipientEmail = formData.TryGetProperty("recipientEmail", out var r) ? r.GetString() : "";
    var successMessage = formData.TryGetProperty("successMessage", out var s) ? s.GetString() : "Thank you for your message!";
}

<section style="padding: 60px 20px; background: white;">
    <div style="max-width: 600px; margin: 0 auto;">
        @if (!string.IsNullOrEmpty(title))
        {
            <h2 class="section-title">@title</h2>
        }
        
        @if (!string.IsNullOrEmpty(description))
        {
            <p style="text-align: center; margin-bottom: 30px;">@description</p>
        }
        
        <form onsubmit="submitContactForm(event, '@Model.LandingPageId')">
            <div class="form-group">
                <label>Your Name</label>
                <input type="text" name="name" required>
            </div>
            
            <div class="form-group">
                <label>Your Email</label>
                <input type="email" name="email" required>
            </div>
            
            <div class="form-group">
                <label>Message</label>
                <textarea name="message" rows="5" required></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%;">Send Message</button>
        </form>
    </div>
</section>

<script>
    async function submitContactForm(e, pageId) {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = {
            pageId: parseInt(pageId),
            formName: 'ContactForm',
            email: formData.get('email'),
            formData: {
                name: formData.get('name'),
                email: formData.get('email'),
                message: formData.get('message')
            }
        };
        
        try {
            const response = await fetch('/api/formsubmission', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            if (response.ok) {
                alert('@successMessage');
                e.target.reset();
            } else {
                alert('Error submitting form');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error submitting form');
        }
    }
</script>
