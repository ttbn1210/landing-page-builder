@page "{slug}"
@model ViewModel
@{
    ViewData["Title"] = Model.LandingPage?.Title ?? "Landing Page";
}

<style>
    body { margin: 0; padding: 0; }
    .page-container { min-height: 100vh; }
    .hero-section {
        padding: 80px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-align: center;
        background-size: cover;
        background-position: center;
    }
    .hero-section h1 { font-size: 3rem; margin: 0 0 20px 0; }
    .hero-section p { font-size: 1.2rem; margin: 0 0 30px 0; }
    .features-section { padding: 60px 20px; background: #f8f9fa; }
    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }
    .feature-item { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .feature-icon { font-size: 2.5rem; margin-bottom: 15px; }
    .feature-item h3 { margin: 15px 0 10px 0; }
    .testimonials-section { padding: 60px 20px; background: white; }
    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }
    .testimonial-item { background: #f8f9fa; padding: 30px; border-radius: 8px; border-left: 4px solid #007bff; }
    .testimonial-item p { font-style: italic; margin: 15px 0; }
    .testimonial-author { font-weight: bold; margin-top: 15px; }
    .cta-section { padding: 80px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; text-align: center; }
    .cta-section h2 { font-size: 2.5rem; margin: 0 0 20px 0; }
    .cta-section p { font-size: 1.1rem; margin: 0 0 30px 0; }
    .btn { display: inline-block; padding: 12px 30px; border-radius: 5px; text-decoration: none; font-weight: bold; cursor: pointer; border: none; font-size: 1rem; }
    .btn-primary { background: #007bff; color: white; }
    .btn-primary:hover { background: #0056b3; }
    .btn-light { background: white; color: #333; }
    .btn-light:hover { background: #f0f0f0; }
    .newsletter-section { padding: 60px 20px; background: #f8f9fa; }
    .newsletter-form {
        max-width: 500px;
        margin: 30px auto;
        display: flex;
        gap: 10px;
    }
    .newsletter-form input { flex: 1; padding: 12px; border: none; border-radius: 5px; }
    .contact-form {
        max-width: 600px;
        margin: 30px auto;
    }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
    .form-group input,
    .form-group textarea { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-family: inherit; }
    .section-title { text-align: center; font-size: 2rem; margin: 40px 0 30px 0; }
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        max-width: 1200px;
        margin: 30px auto;
    }
    .gallery-item img { width: 100%; height: 250px; object-fit: cover; border-radius: 8px; }
</style>

@if (Model.LandingPage != null)
{
    <div class="page-container">
        @if (Model.LandingPage.LogoUrl != null)
        {
            <header style="background-color: @Model.LandingPage.HeaderColor; padding: 20px;">
                <img src="@Model.LandingPage.LogoUrl" alt="Logo" style="max-height: 50px;">
            </header>
        }

        <main>
            @foreach (var component in Model.LandingPage.Components.OrderBy(c => c.Order))
            {
                @switch(component.ComponentName)
                {
                    case "Hero":
                        @await Html.PartialAsync("ComponentRenderers/HeroRenderer", component)
                        break;
                    case "Features":
                        @await Html.PartialAsync("ComponentRenderers/FeaturesRenderer", component)
                        break;
                    case "Testimonials":
                        @await Html.PartialAsync("ComponentRenderers/TestimonialsRenderer", component)
                        break;
                    case "CallToAction":
                        @await Html.PartialAsync("ComponentRenderers/CTARenderer", component)
                        break;
                    case "TextContent":
                        @await Html.PartialAsync("ComponentRenderers/TextContentRenderer", component)
                        break;
                    case "Gallery":
                        @await Html.PartialAsync("ComponentRenderers/GalleryRenderer", component)
                        break;
                    case "Newsletter":
                        @await Html.PartialAsync("ComponentRenderers/NewsletterRenderer", component)
                        break;
                    case "ContactForm":
                        @await Html.PartialAsync("ComponentRenderers/ContactFormRenderer", component)
                        break;
                    default:
                        <div style="padding: 20px; background: #f0f0f0; margin: 20px;">
                            <p>Unknown component type: @component.ComponentName</p>
                        </div>
                        break;
                }
            }
        </main>

        <footer style="background-color: @Model.LandingPage.FooterColor; padding: 40px 20px; text-align: center; color: #666;">
            <p>&copy; @DateTime.Now.Year. All rights reserved.</p>
        </footer>
    </div>
}
else
{
    <div class="alert alert-warning">Landing page not found.</div>
}

<script>
    // Track page view
    async function trackPageView() {
        try {
            const pageId = @(Model.LandingPage?.Id ?? 0);
            await fetch('/api/analytics/track', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    pageId: pageId,
                    referrer: document.referrer
                })
            });
        } catch (e) {
            console.log('Analytics tracking skipped');
        }
    }
    trackPageView();
</script>
