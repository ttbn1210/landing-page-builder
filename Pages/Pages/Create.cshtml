@page
@model CreateModel
@{
    ViewData["Title"] = "Create Landing Page";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>Create New Landing Page</h1>
            <form method="post" class="mt-4">
                <div class="mb-3">
                    <label for="Title" class="form-label">Page Title</label>
                    <input type="text" class="form-control @(ModelState.ContainsKey("LandingPage.Title") && !ModelState["LandingPage.Title"].Errors.Any() ? "" : "")" 
                           id="Title" asp-for="LandingPage.Title" placeholder="e.g., My Awesome Product">
                    <span asp-validation-for="LandingPage.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="Slug" class="form-label">Page Slug</label>
                    <input type="text" class="form-control" id="Slug" asp-for="LandingPage.Slug" placeholder="e.g., my-awesome-product">
                    <small class="form-text text-muted">URL-friendly version of your title</small>
                    <span asp-validation-for="LandingPage.Slug" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="Description" class="form-label">Description</label>
                    <textarea class="form-control" id="Description" asp-for="LandingPage.Description" rows="3" placeholder="Brief description of your landing page"></textarea>
                </div>

                <div class="mb-3">
                    <label for="MetaDescription" class="form-label">Meta Description</label>
                    <input type="text" class="form-control" id="MetaDescription" asp-for="LandingPage.MetaDescription" placeholder="SEO meta description">
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="IsPublished" asp-for="LandingPage.IsPublished">
                        <label class="form-check-label" for="IsPublished">Publish immediately</label>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Page</button>
                    <a href="/Dashboard" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
