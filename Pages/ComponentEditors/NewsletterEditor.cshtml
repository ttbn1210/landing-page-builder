@model PageComponent

<form class="component-form">
    <div class="mb-3">
        <label class="form-label fw-bold">📧 Title</label>
        <input type="text" class="form-control" name="title" placeholder="Subscribe to Our Newsletter" value="Subscribe to Our Newsletter">
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">📝 Description</label>
        <textarea class="form-control" name="description" rows="2" placeholder="Get updates delivered to your inbox"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">💬 Placeholder Text</label>
        <input type="text" class="form-control" name="placeholder" placeholder="Enter your email" value="Enter your email">
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">🔘 Button Text</label>
        <input type="text" class="form-control" name="buttonText" placeholder="Subscribe" value="Subscribe">
    </div>
</form>
