@model PageComponent

<form class="component-form">
    @{
        var heroData = string.IsNullOrEmpty(Model.Content) 
            ? new { headline = "", subheadline = "", ctaText = "", ctaLink = "", backgroundImage = "" }
            : System.Text.Json.JsonSerializer.Deserialize<dynamic>(Model.Content);
    }
    
    <div class="mb-3">
        <label class="form-label fw-bold">🎯 Headline</label>
        <input type="text" class="form-control" name="headline" value="@heroData?.GetProperty("headline").GetString()" placeholder="Main headline">
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">📝 Subheadline</label>
        <input type="text" class="form-control" name="subheadline" value="@heroData?.GetProperty("subheadline").GetString()" placeholder="Supporting text">
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">🖼️ Background Image URL</label>
        <input type="url" class="form-control" name="backgroundImage" value="@heroData?.GetProperty("backgroundImage").GetString()" placeholder="https://...">
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">🔘 Button Text</label>
            <input type="text" class="form-control" name="ctaText" value="@heroData?.GetProperty("ctaText").GetString()" placeholder="e.g., Get Started">
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">🔗 Button Link</label>
            <input type="url" class="form-control" name="ctaLink" value="@heroData?.GetProperty("ctaLink").GetString()" placeholder="https://...">
        </div>
    </div>

    <div class="alert alert-info small">
        <strong>💡 Tip:</strong> Use high-quality images (1920x600px recommended) for best results.
    </div>
</form>
